# deploy/.env — 이 파일을 복사해 값을 채운다: cp .env.example .env
# 비밀값은 저장소에 커밋하지 않는다 (.env는 .gitignore 대상)

# [필수] PostgreSQL 비밀번호
POSTGRES_PASSWORD=change-me

# [필수] API 접속 토큰 — 프론트 첫 접속 시 입력하는 값
SOC_API_TOKEN=change-me

# 웹 포트 (기본 8080)
HTTP_PORT=8080

# LLM 정책 — 사내 기본: 외부(사외) LLM 차단, on-prem만 사용
SOC_ALLOW_EXTERNAL_LLM=false
SOC_ADVISORY_PROVIDERS=openai_compat
# 사내 on-prem OpenAI 호환 API (미설정 시 결정론 fallback으로만 동작)
SOC_ONPREM_BASE_URL=
SOC_ONPREM_API_KEY=
SOC_ONPREM_MODEL=onprem-default

# 최초 기동 시 synthetic fixture 시드 여부 (데모/검증용 — 실데이터 운영은 false)
SEED_FIXTURES=false

# DB 커넥션 풀 상한
SOC_ONTOLOGY_POOL_MAX=8
